	chain sw_AllowICMPs {
		meta l4proto icmp icmp type destination-unreachable accept
		meta l4proto icmp icmp type time-exceeded accept
		meta l4proto icmp icmp type parameter-problem accept
		meta l4proto icmp icmp type echo-request accept
		meta l4proto icmp icmp type echo-reply accept
	}

	chain sw_BLACKLIST {
		fib daddr type broadcast drop
		fib daddr type multicast drop
		meta l4proto tcp ct state new tcp flags & syn 0 drop
		ct state invalid drop
		meta l4proto udp udp sport 53 ct state new drop
		drop
	}

	chain sw_Broadcast {
		fib daddr type broadcast drop
		fib daddr type anycast drop
	}

	chain sw_DNSAmp {
		# DNS amplification
		meta l4proto udp udp sport 53 ct state new drop
		# DNS amplification
		meta l4proto udp udp dport 53 drop
	}

	chain sw_Drop {
		fib daddr type broadcast drop
		fib daddr type multicast drop
		# dropNotSyn
		meta l4proto tcp ct state new tcp flags & syn 0 drop
		# dropInvalid
		ct state invalid drop
		drop
	}

	chain sw_DropDNSrep {
		# DNS amplification
		meta l4proto udp udp sport 53 ct state new drop
	}

	chain sw_DropSmurfs {
		# smurf
		fib saddr type broadcast drop
	}

	chain sw_Established {
		ct state established accept
	}

	chain sw_FIN {
		meta l4proto tcp tcp flags & fin fin ct state new drop
	}

	chain sw_Invalid {
		ct state invalid drop
	}

	chain sw_Multicast {
		fib daddr type multicast drop
	}

	chain sw_RST {
		meta l4proto tcp tcp flags & rst rst limit rate 2/second burst 5 packets accept
		meta l4proto tcp tcp flags & rst rst drop
	}

	chain sw_Reject {
		fib daddr type broadcast drop
		fib daddr type multicast drop
		# dropNotSyn
		meta l4proto tcp ct state new tcp flags & syn 0 drop
		# dropInvalid
		ct state invalid drop
		reject
	}

	chain sw_TCPFlags {
		meta l4proto tcp tcp flags & (fin | syn) fin | syn drop
		meta l4proto tcp tcp flags & (syn | rst) syn | rst drop
		meta l4proto tcp tcp flags & (fin | rst) fin | rst drop
		meta l4proto tcp tcp flags & (fin | urg | psh) fin | urg | psh drop
		meta l4proto tcp tcp flags & (fin | syn | rst | psh | ack | urg) 0 drop
	}

	chain sw_allowinUPnP {
		# SSDP
		meta l4proto udp udp dport 1900 accept
		# UPnP
		meta l4proto tcp tcp dport 5000 accept
	}

	chain sw_dropInvalid {
		ct state invalid drop
	}

	chain sw_dropNotSyn {
		meta l4proto tcp ct state new tcp flags & syn 0 drop
	}

	chain sw_rejNotSyn {
		meta l4proto tcp ct state new tcp flags & syn 0 reject
	}

	chain tunneled-dmz {
		ct state invalid drop
		meta l4proto tcp jump sw_TCPFlags
		ct state { invalid, new, untracked } jump sw_DropSmurfs
		meter lograte_tunneled_dmz { ip daddr limit rate 5/second burst 10 packets } log level info prefix "Shorewall:tunneled-dmz:DROP: "
		jump sw_Reject
	}

