		ip daddr 192.0.2.53 meta l4proto udp udp dport 53 meta secpath exists accept
		ip daddr 192.0.2.53 meta l4proto tcp tcp dport 53 meta secpath exists accept
		meta nfproto ipv4 meta l4proto icmp icmp type 8 meta secpath exists accept
		meter lograte_tunneled_fw { ip daddr limit rate 5/second burst 10 packets } log level info prefix "Shorewall:tunneled-fw:DROP: "
