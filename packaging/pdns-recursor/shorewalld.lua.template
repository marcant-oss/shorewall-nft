-- shorewalld dnstap integration for pdns_recursor
--
-- Installs a dnstap FrameStream exporter that sends every
-- CLIENT_RESPONSE to the shorewalld consumer at a unix socket.
-- The shorewalld process reads these frames and populates
-- nft sets (e.g. dns_github_com_v4) so firewall rules can
-- filter on qname without doing live resolution.
--
-- Placement:
--   /etc/powerdns/recursor.d/shorewalld.lua
--
-- After editing, reload pdns_recursor:
--   systemctl reload pdns-recursor
-- or for named-netns instances:
--   ip netns exec rns1 systemctl reload pdns-recursor
--
-- Socket path:
--   shorewalld creates and owns /run/shorewalld/dnstap.sock
--   (0660 root:shorewall). pdns_recursor needs to be in the
--   shorewall group, or the socket mode needs to be 0666.
--
-- Blocking: the dnstap writer inside pdns_recursor uses an
-- internal bounded queue and drops frames on overflow. The
-- resolver hot path is NOT blocked by shorewalld being slow
-- or dead. Drop counter is visible in rec_control get-all.

dnstapFrameStreamServer({"/run/shorewalld/dnstap.sock"},
{
    -- CLIENT_QUERY is not useful for shorewalld; skip it.
    logQueries   = false,

    -- CLIENT_RESPONSE is the event shorewalld consumes.
    -- Cache-hits and miss-then-resolve both fire this event,
    -- which is the behaviour we want (every response to a
    -- client reveals an IP the client may soon connect to).
    logResponses = true,
})

-- OPTIONAL: producer-side qname allowlist.
