#!/usr/bin/make -f
# debian/rules for shorewall-nft — monorepo, three sub-packages.
#
# Primary wheel (shorewall-nft core) is built by pybuild from
# packages/shorewall-nft/.  The shorewalld and shorewall-nft-simlab
# wheels are installed afterwards via pip --no-deps so they land in
# the same binary package without a separate pybuild invocation.
export PYBUILD_NAME = shorewall_nft
export PYBUILD_SYSTEM = pyproject
export PYBUILD_DIR = packages/shorewall-nft

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	# Install shorewalld and simlab into the same staging tree.
	# pip's Debian sysconfig scheme ignores --prefix for scripts and places
	# them under usr/local/bin/ — use python3 -m build + python3 -m installer
	# instead, which honours the system sysconfig and writes to usr/bin/.
	cd packages/shorewalld && python3 -m build --wheel --no-isolation --outdir /tmp/shorewalld-wheel
	python3 -m installer --destdir=debian/shorewall-nft /tmp/shorewalld-wheel/*.whl
	cd packages/shorewall-nft-simlab && python3 -m build --wheel --no-isolation --outdir /tmp/simlab-wheel
	python3 -m installer --destdir=debian/shorewall-nft /tmp/simlab-wheel/*.whl
	# Shell completions, man pages, systemd units.
	install -D -m 0644 tools/completions/shorewall-nft.bash \
	    debian/shorewall-nft/usr/share/bash-completion/completions/shorewall-nft
	install -D -m 0644 tools/completions/shorewall-nft.zsh \
	    debian/shorewall-nft/usr/share/zsh/vendor-completions/_shorewall-nft
	install -D -m 0644 tools/completions/shorewall-nft.fish \
	    debian/shorewall-nft/usr/share/fish/vendor_completions.d/shorewall-nft.fish
	install -D -m 0644 tools/man/shorewall-nft.8 \
	    debian/shorewall-nft/usr/share/man/man8/shorewall-nft.8
	install -D -m 0644 packaging/systemd/shorewall-nft.service \
	    debian/shorewall-nft/lib/systemd/system/shorewall-nft.service
	install -D -m 0644 packaging/systemd/shorewall-nft@.service \
	    debian/shorewall-nft/lib/systemd/system/shorewall-nft@.service
	install -D -m 0644 packaging/systemd/shorewalld.service \
	    debian/shorewall-nft/lib/systemd/system/shorewalld.service
	install -D -m 0644 packaging/systemd/shorewalld@.service \
	    debian/shorewall-nft/lib/systemd/system/shorewalld@.service

override_dh_auto_test:
	# Tests run in the CI unit-tests job; skip during deb build.
	@echo "Skipping tests at deb-build time (covered by CI unit-tests)"
