# ─────────────────────────────────────────────────────────────
# Deployment secrets — tools/deploy.json.example is the committed
# template, tools/deploy.json holds the real credentials.
# ─────────────────────────────────────────────────────────────
tools/deploy.json

# ─────────────────────────────────────────────────────────────
# Simlab per-probe pcaps — one file per failed probe. Useful
# locally for wireshark triage but far too many files (and too
# session-specific) to keep in git history. Keep report.json /
# report.md / mismatches.txt / fail-pcaps.txt (the grep-friendly
# index); drop the raw pcap dir.
# ─────────────────────────────────────────────────────────────
docs/testing/simlab-reports/*/fail-pcaps/

# ─────────────────────────────────────────────────────────────
# Claude Code local state
# ─────────────────────────────────────────────────────────────
.claude/

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ─────────────────────────────────────────────────────────────
# Build artifacts
# ─────────────────────────────────────────────────────────────
dist/
build/
site/             # mkdocs output

# ─────────────────────────────────────────────────────────────
# Test / debug temp files
# ─────────────────────────────────────────────────────────────
*.nft.tmp
/tmp/shorewall-next-sim-*
*.bak
*~

# ─────────────────────────────────────────────────────────────
# Plugin caches and secrets
# WARNING: these may contain API tokens or customer data.
# Never commit them.
# ─────────────────────────────────────────────────────────────
plugins/*-cache.json
plugins/*.token
**/netbox-cache.json
**/*.token

# ─────────────────────────────────────────────────────────────
# Generated merged configs (should be reproducible from source)
# ─────────────────────────────────────────────────────────────
/etc/shorewall46/
etc/shorewall46/

# ─────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─────────────────────────────────────────────────────────────
# Project-local overrides
# ─────────────────────────────────────────────────────────────
/local/
/scratch/
