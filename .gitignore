# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# ─────────────────────────────────────────────────────────────
# Build artifacts
# ─────────────────────────────────────────────────────────────
dist/
build/
site/             # mkdocs output

# ─────────────────────────────────────────────────────────────
# Test / debug temp files
# ─────────────────────────────────────────────────────────────
*.nft.tmp
/tmp/shorewall-next-sim-*
*.bak
*~

# ─────────────────────────────────────────────────────────────
# Plugin caches and secrets
# WARNING: these may contain API tokens or customer data.
# Never commit them.
# ─────────────────────────────────────────────────────────────
plugins/*-cache.json
plugins/*.token
**/netbox-cache.json
**/*.token

# ─────────────────────────────────────────────────────────────
# Generated merged configs (should be reproducible from source)
# ─────────────────────────────────────────────────────────────
/etc/shorewall46/
etc/shorewall46/

# ─────────────────────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─────────────────────────────────────────────────────────────
# Project-local overrides
# ─────────────────────────────────────────────────────────────
/local/
/scratch/
