#!/bin/sh
# run-netns — thin wrapper around `ip netns` for unprivileged use via sudo
#
# This script exists so that operators can grant NOPASSWD sudo access to
# a single, audit-friendly entry point instead of all of `ip`. The wrapper
# forwards every argument verbatim to `ip netns`, so the usual subcommands
# are available:
#
#   run-netns list
#   run-netns add myns
#   run-netns delete myns
#   run-netns exec myns nft list ruleset
#   run-netns exec myns ip link set lo up
#
# PRIMARY USE: test isolation — the integration test suite (test_cli_integration.py
# and test_netns_routing.py) uses `sudo run-netns exec <ns> <cmd>` to create and
# enter network namespaces for isolated test runs.
#
# FALLBACK USE: non-root / no libnft — when shorewall-nft is invoked without
# CAP_SYS_ADMIN (or without python3-nftables installed), NftInterface falls back
# to `sudo run-netns exec` for namespace-entering operations.
#
# PRODUCTION: root systems with python3-nftables installed do NOT use this script
# for CLI operations (start, stop, status, etc.). NftInterface enters namespaces
# directly via setns(2) + libnftables — no fork, no sudo, no exec overhead.
#
# Install this file to /usr/local/bin/run-netns (root-owned, mode 0755)
# and pair it with a sudoers entry allowing the test user NOPASSWD access.
# See tools/sudoers.d-shorewall-nft for the matching sudoers snippet, and
# tools/install-test-tooling.sh for the one-shot installer.

exec /sbin/ip netns "$@"
