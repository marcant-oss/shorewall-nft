# Template file. Copy to /home/avalentin/projects/marcant-fw/shorewall-config/stagelab/stagelab-example-ha.yaml,
# fill in real values (or set STAGELAB_* env vars and run via the env-substitution loader),
# and point the stagelab CLI at the resulting file.
#
# See tools/stagelab-env.example for the full list of variables.
#
# Example stagelab config for the HA-pair test environment.
#
# Topology:
#   ${STAGELAB_TESTER01} (${STAGELAB_MGMT_TESTER01}) — client side, native-mode on eth2.10
#   ${STAGELAB_TESTER02} (${STAGELAB_MGMT_TESTER02}) — server side, native-mode on eth2.20
#   ${STAGELAB_FW_PRIMARY} (${STAGELAB_MGMT_PRIMARY})   — firewall-under-test (primary, exposes /metrics)
#   ${STAGELAB_FW_SECONDARY} (${STAGELAB_MGMT_SECONDARY}) — firewall-under-test (secondary)
#
# Traffic path:
#   tester01 eth2.10 (10.0.10.100) --VLAN 10--> FW --VLAN 20--> eth2.20 (10.0.20.100) on tester02
#
# This YAML uses mode=native on virtio eth2 interfaces — DPDK (mode=dpdk) needs
# SR-IOV hardware which is scheduled to be added later. Switch mode:native ->
# mode:dpdk and add pci_addr + dpdk_cores + hugepages_gib once that's available.

hosts:
  - name: tester01
    address: root@${STAGELAB_MGMT_TESTER01}
    work_dir: /root/shorewall-nft
    isolate_cores: [2, 3]

  - name: tester02
    address: root@${STAGELAB_MGMT_TESTER02}
    work_dir: /root/shorewall-nft
    isolate_cores: [2, 3]

dut:
  kind: external

endpoints:
  # Both endpoints live on VLAN 13 — that VID is carried by the existing
  # br-trunk between tester01 and tester02. Switch to distinct VLANs (with a
  # FW in the middle) once routing policy + FW config allow it.
  - name: client-lan
    host: tester01
    mode: native
    nic: eth2
    vlan: 13
    ipv4: 10.0.13.100/24
    ipv4_gw: 10.0.13.200          # peer endpoint as surrogate GW
    rss_queues: 4
    irq_affinity: [2, 3]

  - name: server-wan
    host: tester02
    mode: native
    nic: eth2
    vlan: 13
    ipv4: 10.0.13.200/24
    ipv4_gw: 10.0.13.100          # peer endpoint as surrogate GW
    rss_queues: 4
    irq_affinity: [2, 3]

scenarios:
  - id: baseline_throughput
    kind: throughput
    source: client-lan
    sink: server-wan
    proto: tcp
    duration_s: 10
    parallel: 4
    expect_min_gbps: 0.5        # virtio realistic; raise to 8.0 on SR-IOV

  - id: tune_sweep
    kind: tuning_sweep
    source: client-lan
    sink: server-wan
    proto: tcp
    duration_per_point_s: 2
    rss_queues: [1, 2, 4]
    rmem_max: [1048576, 16777216, 67108864]

metrics:
  poll_interval_s: 5
  collect: [nft_counters, conntrack_stats]
  sources:
    - kind: prometheus
      name: fw-primary
      url: http://${STAGELAB_MGMT_PRIMARY}:9748/metrics
      timeout_s: 5.0
      metric_prefix_allow: ["shorewalld_"]
    - kind: prometheus
      name: fw-secondary
      url: http://${STAGELAB_MGMT_SECONDARY}:9748/metrics
      timeout_s: 5.0
      metric_prefix_allow: ["shorewalld_"]

report:
  output_dir: /tmp/stagelab-reports
  keep_pcaps: failed_only
