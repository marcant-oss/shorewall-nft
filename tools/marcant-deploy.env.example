# marcant-deploy.env — test-host deployment secrets + mappings.
#
# Copy to tools/marcant-deploy.env and fill in. The real file is
# .gitignored. setup-remote-test-host.sh sources this and writes
# /etc/shorewall46/plugins/{plugins.conf,netbox.toml,netbox.token}
# on the target.
#
# FUTURE (planned, not yet implemented): the same NETBOX_* keys may
# alternatively live inside /etc/shorewall46/shorewall.conf as
# shell-style assignments, and the netbox plugin will prefer those
# over plugins/netbox.toml if present. In addition, a global CLI
# flag ``--override-json JSON`` will dynamically overlay arbitrary
# shorewall.conf settings at runtime (also covers the "no
# shorewall.conf present" case). When that lands, this .env still
# works — it just becomes one of several sources.

# ── Netbox (IPv4 ↔ IPv6 translation source) ─────────────────────
NETBOX_URL="https://netbox.example.com/"
NETBOX_TOKEN=""                        # read-only API token
NETBOX_CACHE_TTL=86400
NETBOX_TIMEOUT=30
NETBOX_DIRTY_FLUSH_INTERVAL=50
NETBOX_PRIORITY=100

# Bulk-fetch narrowing — only these ranges are pre-cached at compile
# time. Space-separated list of CIDRs.
NETBOX_BULK_SUBNETS="203.0.113.0/24 198.51.100.0/21 198.51.100.128/24 198.51.100.64/21"
