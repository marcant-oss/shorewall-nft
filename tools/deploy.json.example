{
  "schema_version": 1,
  "_comment": "Deployment overlay consumed by tools/setup-remote-test-host.sh via `shorewall-nft config import --to /etc/shorewall46 --force`. Copy to tools/deploy.json (gitignored) and substitute real values, or run through an env-substitution wrapper that expands ${NETBOX_URL} / ${NETBOX_API_TOKEN} from the environment. See tools/stagelab-env.example.",

  "plugins.conf": {
    "plugins": [
      { "name": "netbox", "enabled": true }
    ]
  },

  "plugins/netbox.toml": {
    "url":                  "${NETBOX_URL}",
    "token_file":           "/etc/shorewall46/plugins/netbox.token",
    "priority":             100,
    "cache_ttl":            86400,
    "timeout":              30,
    "dirty_flush_interval": 50,
    "bulk_subnets": [
      "203.0.113.0/24",
      "2001:db8::/32"
    ]
  },

  "plugins/netbox.token": "${NETBOX_API_TOKEN}"
}
